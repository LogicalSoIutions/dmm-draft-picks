NODE_ENV=development
SQLITE_PATH=./data/app.db
SESSION_SECRET=replace-with-32-plus-char-secret-value
SESSION_COOKIE_DOMAIN=
KICK_CLIENT_ID=your-kick-client-id
KICK_CLIENT_SECRET=your-kick-client-secret
KICK_REDIRECT_URI=http://localhost:15000/auth/kick/callback
KICK_SCOPE=user:read
KICK_API_BASE_URL=https://api.kick.com/public/v1
TOKEN_ENCRYPTION_KEY_VERSION=1
TOKEN_ENCRYPTION_KEY_V1=replace-with-32-byte-base64-or-hex-key
DRAFT_RATE_LIMIT_PER_MINUTE_USER=60
DRAFT_NEW_SUBMISSION_DEADLINE=2026-05-31T19:00:00+01:00
ADMIN_KICK_USERNAMES=
# When true, official-draft results (stats comparison, winners) are visible only to admins.
TESTING_WINNER=false
